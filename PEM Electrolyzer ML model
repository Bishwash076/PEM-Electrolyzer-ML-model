# HELPERS
# ------------------------------------------------------------
def compute_metrics(yt, yp, label=""):
    rmse = np.sqrt(mean_squared_error(yt, yp))
    mae  = mean_absolute_error(yt, yp)
    r2   = r2_score(yt, yp)
    mape = np.mean(np.abs((yt - yp) / (np.abs(yt) + EPS))) * 100
    print(f"  [{label}] R²={r2:.4f} | RMSE={rmse:.4f} | MAE={mae:.4f} | MAPE={mape:.2f}%")
    return rmse, mae, r2, mape

def build_xgb(early=40):
    return xgb.XGBRegressor(
        n_estimators=600, max_depth=6, learning_rate=0.03,
        subsample=0.8, colsample_bytree=0.7, min_child_weight=3,
        reg_alpha=0.1, reg_lambda=1.0, gamma=0.1,
        tree_method='hist', device=XGB_DEVICE,
        early_stopping_rounds=early, random_state=42, n_jobs=-1
    )

def build_lgb():
    params = dict(
        n_estimators=600, max_depth=6, learning_rate=0.03,
        subsample=0.8, colsample_bytree=0.7, min_child_samples=20,
        reg_alpha=0.1, reg_lambda=1.0, random_state=42, n_jobs=-1, verbose=-1
    )
    if USE_GPU:
        params["device"] = "gpu"
    return lgb.LGBMRegressor(**params)

def fit_ensemble(X_tr, y_tr_log, X_te, y_te_log, y_te_raw, label):
    scl = RobustScaler()
    Xtr = scl.fit_transform(X_tr)
    Xte = scl.transform(X_te)
    xm  = build_xgb()
    lm  = build_lgb()
    xm.fit(Xtr, y_tr_log, eval_set=[(Xte, y_te_log)], verbose=False)
    lm.fit(Xtr, y_tr_log,
           eval_set=[(Xte, y_te_log)],
           callbacks=[lgb.early_stopping(40, verbose=False), lgb.log_evaluation(-1)])
    pred_log = 0.55 * xm.predict(Xte) + 0.45 * lm.predict(Xte)
    ep = np.expm1(pred_log)
    print(f"\n  ▶ {label}")
    r, m, r2, mp = compute_metrics(y_te_raw, ep, label)
    return xm, lm, ep, Xtr, Xte, scl, r, m, r2, mp

def capture_shap_plot(plot_fn, figsize=(7, 7), dpi=150):
    plt.close('all')
    plot_fn()
    fig = plt.gcf()
    fig.set_size_inches(*figsize)
    buf = io.BytesIO()
    fig.savefig(buf, format='png', dpi=dpi, bbox_inches='tight')
    buf.seek(0)
    img = Image.open(buf).copy()
    plt.close('all')
    return img

def add_engineered_features(frame, v_ref):
    out = frame.copy()
    V  = out.get(VOLT_COL, pd.Series(0, index=out.index))
    I  = out.get(CURR_COL, pd.Series(0, index=out.index))
    P  = out.get(PWR_COL, pd.Series(0, index=out.index))
    WP = out.get(WAVE_PWR_COL, pd.Series(0, index=out.index))
    Fm = out.get('IVAL_f_FM011_Flow', pd.Series(1, index=out.index))

    if VOLT_COL in out.columns and CURR_COL in out.columns:
        out['Feat_PowerVI_kW']       = (V * I) / 1000.0
        out['Feat_StackResistance']  = V / (I + EPS)
        out['Feat_VoltageRatio']     = V / (v_ref + EPS)
    if PWR_COL in out.columns and VOLT_COL in out.columns and CURR_COL in out.columns:
        out['Feat_PowerMismatch_kW'] = P - ((V * I) / 1000.0)
    if PWR_COL in out.columns:
        out['Feat_PowerPerFlow']     = P / (Fm + EPS)
    if WAVE_PWR_COL in out.columns and PWR_COL in out.columns:
        out['Feat_WavePSURatio']     = WP / (P + EPS)
        out['Feat_PSUWaveGap_kW']    = WP - P
    if CURR_COL in out.columns:
        out['Feat_log_Current']      = np.log1p(np.clip(I, 0, None))
        out['Feat_CurrentSquared']   = I ** 2
    if WAVE_PWR_COL in out.columns:
        out['Feat_log_WavePower']    = np.log1p(np.clip(WP, 0, None))
    if 'H2E_f_TE218_Temp' in out.columns and 'H2E_f_TE338_Temp' in out.columns:
        out['Feat_TempGradient']     = out['H2E_f_TE218_Temp'] - out['H2E_f_TE338_Temp']
    if 'H2E_f_DPS340_DPdegC' in out.columns and 'H2E_f_DPS341_DPdegC' in out.columns:
        out['Feat_DewPointDiff']     = out['H2E_f_DPS340_DPdegC'] - out['H2E_f_DPS341_DPdegC']
    if 'H2E_f_PT307_Pressure' in out.columns and 'H2E_f_PT312_Pressure' in out.columns:
        out['Feat_PressureRatio']    = out['H2E_f_PT307_Pressure'] / (out['H2E_f_PT312_Pressure'] + EPS)
    if 'H2E_f_RS209_Resistivity' in out.columns and 'H2E_f_RS507_Resistivity' in out.columns:
        out['Feat_ResistivityRatio'] = out['H2E_f_RS209_Resistivity'] / (out['H2E_f_RS507_Resistivity'] + EPS)
    tt_cols  = ['H2E_f_TT645_Temp', 'H2E_f_TT646_Temp', 'H2E_f_TT647_Temp', 'H2E_f_TT648_Temp']
    tt_exist = [c for c in tt_cols if c in out.columns]
    if tt_exist:
        out['Feat_TempAvgCell'] = out[tt_exist].mean(axis=1)
    return out

# ============================================================
# LOAD & CLEAN
# ============================================================
df = pd.read_csv("dataset.csv", index_col=0, parse_dates=True)
df.columns = df.columns.str.strip()
df = df.sort_index().dropna()
print(f"\nRaw shape: {df.shape}")

if TARGET not in df.columns:
    raise KeyError(f"Missing target column: {TARGET}")

df = df[df[TARGET] > H2_THRESHOLD].copy()
Q1, Q3 = df[TARGET].quantile(0.02), df[TARGET].quantile(0.98)
IQR    = Q3 - Q1
df     = df[df[TARGET].between(Q1 - 2.5 * IQR, Q3 + 2.5 * IQR)].copy()
print(f"After cleaning (H₂ > {H2_THRESHOLD} kg/h): {df.shape}")
print(f"H₂ range: [{df[TARGET].min():.4f}, {df[TARGET].max():.4f}] kg/h")

# ============================================================
# SPLIT & FEATURE ENGINEERING
# ============================================================
split_idx     = int(0.80 * len(df))
df_train_raw0 = df.iloc[:split_idx].copy()
df_test_raw0  = df.iloc[split_idx:].copy()
v_ref_train   = df_train_raw0[VOLT_COL].median() if VOLT_COL in df_train_raw0.columns else 1.0
df_train_raw  = add_engineered_features(df_train_raw0, v_ref_train)
df_test_raw   = add_engineered_features(df_test_raw0,  v_ref_train)
df_all        = pd.concat([df_train_raw, df_test_raw], axis=0)

exclude_cols = [TARGET]
if not USE_EFFICIENCY_AS_INPUT and EFF_COL in df_all.columns:
    exclude_cols.append(EFF_COL)

ALL_FEATS     = [c for c in df_all.columns if c not in exclude_cols]
corr_matrix   = df_train_raw[ALL_FEATS].corr().abs()
upper         = corr_matrix.where(np.triu(np.ones(corr_matrix.shape), k=1).astype(bool))
drop_corr     = [col for col in upper.columns if any(upper[col] > 0.92)]
FULL_FEATS    = [c for c in ALL_FEATS if c not in drop_corr]
RAW_FEATS     = [c for c in FULL_FEATS if not c.startswith('Feat_')]
ENG_FEATS     = [c for c in FULL_FEATS if c.startswith('Feat_')]
REDUCED_FEATS = [c for c in FULL_FEATS if any(k in c for k in ['Voltage','Temp','Flow','TT6','TE2','TE3','FM0','Pressure','Resistivity'])]
NO_ELEC_FEATS = [c for c in FULL_FEATS if not any(k in c for k in ['Current','Voltage','Power','PSU','Wave','Feat_PowerVI_kW','Feat_PowerMismatch_kW','Feat_PSUWaveGap_kW','Feat_log_Current','Feat_CurrentSquared','Feat_WavePSURatio','Feat_log_WavePower','Feat_StackResistance','Feat_VoltageRatio', EFF_COL])]

print(f"\nDropped (r > 0.92): {drop_corr}")
print(f"Full: {len(FULL_FEATS)} | Raw: {len(RAW_FEATS)} | Eng: {len(ENG_FEATS)} | Reduced: {len(REDUCED_FEATS)} | No-Elec: {len(NO_ELEC_FEATS)}")

# TRAIN / TEST ARRAYS
y_train_raw = df_train_raw[TARGET].values
y_test_raw  = df_test_raw[TARGET].values
y_train_log = np.log1p(y_train_raw)
y_test_log  = np.log1p(y_test_raw)

scaler  = RobustScaler()
X_train = scaler.fit_transform(df_train_raw[FULL_FEATS].values.astype(np.float32))
X_test  = scaler.transform(df_test_raw[FULL_FEATS].values.astype(np.float32))
print(f"\nFull model — Train: {X_train.shape} | Test: {X_test.shape}")

# BASELINE + 5-FOLD CV
y_baseline = np.expm1(np.full(len(y_test_raw), y_train_log.mean()))
r2_base    = r2_score(y_test_raw, y_baseline)
rmse_base  = np.sqrt(mean_squared_error(y_test_raw, y_baseline))

kf = KFold(n_splits=5, shuffle=False)
print("\n--- 5-Fold Chronological CV (XGBoost, Full Features) ---")
cv_r2, cv_rmse = [], []
for fold, (tr_i, va_i) in enumerate(kf.split(X_train)):
    Xtr, Xva = X_train[tr_i], X_train[va_i]
    ytr, yva = y_train_log[tr_i], y_train_log[va_i]
    m = build_xgb(early=30)
    m.fit(Xtr, ytr, eval_set=[(Xva, yva)], verbose=False)
    pred = np.expm1(m.predict(Xva))
    true = np.expm1(yva)
    cv_r2.append(r2_score(true, pred))
    cv_rmse.append(np.sqrt(mean_squared_error(true, pred)))
    print(f"  Fold {fold+1}: R²={cv_r2[-1]:.4f} | RMSE={cv_rmse[-1]:.4f} kg/h")
print(f"  CV R²   = {np.mean(cv_r2):.4f} ± {np.std(cv_r2):.4f}")
print(f"  CV RMSE = {np.mean(cv_rmse):.4f} ± {np.std(cv_rmse):.4f} kg/h")

# ============================================================
# FINAL MODELS
# ============================================================
xgb_model = build_xgb()
xgb_model.fit(X_train, y_train_log, eval_set=[(X_test, y_test_log)], verbose=False)
lgb_model = build_lgb()
lgb_model.fit(X_train, y_train_log, eval_set=[(X_test, y_test_log)],
              callbacks=[lgb.early_stopping(40, verbose=False), lgb.log_evaluation(-1)])

xgb_pred = np.expm1(xgb_model.predict(X_test))
lgb_pred = np.expm1(lgb_model.predict(X_test))
ens_pred = np.expm1(0.55 * xgb_model.predict(X_test) + 0.45 * lgb_model.predict(X_test))
y_true   = y_test_raw.copy()

print("\n=== FINAL TEST METRICS (H₂ Production Rate — kg/h) ===")
rmse_x, mae_x, r2_x, mape_x = compute_metrics(y_true, xgb_pred,  "XGBoost")
rmse_l, mae_l, r2_l, mape_l = compute_metrics(y_true, lgb_pred,  "LightGBM")
rmse_e, mae_e, r2_e, mape_e = compute_metrics(y_true, ens_pred,  "Ensemble")
residuals = y_true - ens_pred
rel_err   = np.abs(residuals) / (np.abs(y_true) + EPS) * 100

# ROBUSTNESS / REDUCED / ABLATION
print("\n=== ROBUSTNESS CHECK ===")
if len(NO_ELEC_FEATS) >= 3:
    _, _, ens_noelec, _, _, _, rmse_noe, mae_noe, r2_noe, mape_noe = fit_ensemble(
        df_train_raw[NO_ELEC_FEATS].values.astype(np.float32), y_train_log,
        df_test_raw[NO_ELEC_FEATS].values.astype(np.float32), y_test_log,
        y_test_raw, "No-Electrical Features")
    r2_drop = r2_e - r2_noe
    print(f"  R² drop = {r2_drop:.4f}")
else:
    r2_noe = mape_noe = rmse_noe = mae_noe = np.nan
    ens_noelec = np.full(len(y_true), np.nan)
    print("  Skipped.")

print("\n=== REDUCED MODEL ===")
if len(REDUCED_FEATS) >= 3:
    _, _, ens_red, _, _, _, rmse_red, mae_red, r2_red, mape_red = fit_ensemble(
        df_train_raw[REDUCED_FEATS].values.astype(np.float32), y_train_log,
        df_test_raw[REDUCED_FEATS].values.astype(np.float32), y_test_log,
        y_test_raw, "Reduced Model")
else:
    ens_red = np.full(len(y_true), np.nan)
    r2_red = rmse_red = mape_red = mae_red = np.nan
    print("  Skipped.")

print("\n=== ABLATION STUDY ===")
ablation_results = {}
for abl_name, abl_feats in [("Raw Only", RAW_FEATS), ("Engineered Only", ENG_FEATS), ("Full (Raw+Eng)", FULL_FEATS)]:
    if len(abl_feats) < 2:
        ablation_results[abl_name] = (np.nan,) * 4
        continue
    _, _, ep, _, _, _, r, m, r2, mp = fit_ensemble(
        df_train_raw[abl_feats].values.astype(np.float32), y_train_log,
        df_test_raw[abl_feats].values.astype(np.float32), y_test_log,
        y_test_raw, abl_name)
    ablation_results[abl_name] = (r, m, r2, mp)

print("\n=== MONOTONICITY CHECK ===")
if CURR_COL in df_test_raw.columns:
    curr_test    = df_test_raw[CURR_COL].values[:len(ens_pred)]
    curr_sorted  = np.argsort(curr_test)
    curr_s       = curr_test[curr_sorted]
    pred_s       = ens_pred[curr_sorted]
    window       = max(10, len(curr_s) // 20)
    pred_rolling = pd.Series(pred_s).rolling(window, center=True).mean().values
    mono_violations = int(np.sum(np.diff(pred_rolling[~np.isnan(pred_rolling)]) < -0.001))
    print(f"  Violations: {mono_violations}")
else:
    mono_violations = np.nan
    print("  Skipped.")

